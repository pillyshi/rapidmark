{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rapidmark.io/schema/result_v1.schema.json",
  "title": "RapidMark Result v1",
  "description": "Canonical schema for RapidMark annotation result files (.result.rapidmark.json). result_version=1.",
  "type": "object",
  "required": ["task_id", "result_version", "exported_at", "texts"],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "description": "ID of the task file this result belongs to (matches definition.id in the .rapidmark.json task file)."
    },
    "result_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Always 1 for this schema."
    },
    "worker": {
      "type": ["string", "null"],
      "description": "Annotator identifier."
    },
    "exported_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of export."
    },
    "texts": {
      "type": "array",
      "description": "Per-text annotation results.",
      "items": {
        "$ref": "#/$defs/TextResult"
      }
    }
  },
  "$defs": {
    "TextResult": {
      "type": "object",
      "required": ["id", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Text ID matching texts[].id in the task file."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "completed", "excluded"],
          "description": "Annotation status for this text."
        },
        "entities": {
          "type": "array",
          "description": "NER entity annotations (NER tasks only).",
          "items": {
            "$ref": "#/$defs/EntityAnnotation"
          }
        },
        "groups": {
          "type": "array",
          "description": "Entity co-reference groups (NER tasks only).",
          "items": {
            "$ref": "#/$defs/EntityGroup"
          }
        },
        "label_id": {
          "type": ["string", "null"],
          "description": "Assigned label ID (classification tasks only)."
        }
      }
    },
    "EntityAnnotation": {
      "type": "object",
      "required": ["id", "start", "end", "quote", "label_id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Entity ID, unique within the text."
        },
        "start": {
          "type": "integer",
          "minimum": 0,
          "description": "Start character offset (inclusive)."
        },
        "end": {
          "type": "integer",
          "minimum": 0,
          "description": "End character offset (exclusive)."
        },
        "quote": {
          "type": "string",
          "description": "Entity surface string."
        },
        "label_id": {
          "type": "string",
          "description": "Label ID matching labels[].id in the task file."
        }
      }
    },
    "EntityGroup": {
      "type": "object",
      "required": ["id", "entity_ids"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Group ID, unique within the text."
        },
        "entity_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "description": "Entity IDs belonging to this group."
        }
      }
    }
  }
}
